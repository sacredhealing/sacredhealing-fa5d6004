# Copy to `.env.local` (gitignored). Vite embeds `VITE_*` at build/dev start — restart dev server after changes.
#
# Polygon JSON-RPC endpoints (optional). If unset, Polymarket bot uses public fallbacks
# (publicnode, meowrpc, 1rpc, ankr — rate limits may apply).
VITE_RPC_URL_1=
VITE_RPC_URL_2=
VITE_RPC_URL_3=
# Aliases supported by the app (same purpose):
# VITE_POLYGON_RPC_URL_1 / _2 / _3
