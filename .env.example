# ============================================
# Sacred Healing - Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# ============================================
# Frontend (Vite) - Client-side variables
# ============================================
# These are exposed to the browser, so use public/anonymous keys only

# Supabase Project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anonymous/Public Key (safe to expose in frontend)
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key-here

# Anthropic (Hand Analyzer palm reading) - optional; if unset, a fallback reading is shown
# VITE_ANTHROPIC_API_KEY=sk-ant-api03-...

# Google Gemini (Siddha Hair Growth / Vision) — optional; unset uses Prakriti questionnaire fallback
# https://aistudio.google.com/app/apikey
# VITE_GEMINI_API_KEY=

# ============================================
# Backend (Supabase Edge Functions)
# ============================================
# These are server-side only and should NEVER be exposed to the frontend
# Set these in Supabase Dashboard > Project Settings > Edge Functions > Secrets

# Supabase Configuration
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-supabase-anon-key-here
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Stripe Payment Processing
# STRIPE_SECRET_KEY=sk_live_... or sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_... (for webhook signature verification)

# Solana Blockchain (SHC Token)
# SHC_TOKEN_MINT=your-shc-token-mint-address
# SOLANA_TREASURY_PRIVATE_KEY=your-solana-treasury-private-key-base58

# Email Service (Resend)
# RESEND_API_KEY=re_...

# AI/Translation Service (Lovable)
# LOVABLE_API_KEY=your-lovable-api-key

# Telegram Integration
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# TELEGRAM_STARGATE_GROUP_ID=your-telegram-group-id

# Agora (Video/Audio Streaming)
# AGORA_APP_ID=your-agora-app-id
# AGORA_APP_CERTIFICATE=your-agora-app-certificate

# ============================================
# Notes:
# ============================================
# 1. Frontend variables (VITE_*) are set in .env file
# 2. Backend variables are set in Supabase Dashboard as Edge Function secrets
# 3. Never commit actual secrets to version control
# 4. Use different keys for development and production environments
