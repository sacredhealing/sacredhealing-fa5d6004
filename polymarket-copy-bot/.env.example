# ─────────────────────────────────────────────────────────────────────────────
# SQI-2050 Polymarket Bot — Environment Variables
# NEVER commit this file to GitHub. Add .env to your .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# 1. POLYGON RPC — Get from Alchemy (free): https://alchemy.com
#    Create App → Network: Polygon Mainnet → Copy HTTPS URL
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE

# 2. POLYMARKET API KEYS — Get from polymarket.com → Settings → API
#    Copy Secret + Passphrase IMMEDIATELY — only shown once
POLY_API_KEY=your_polymarket_api_key
POLY_API_SECRET=your_polymarket_api_secret
POLY_API_PASSPHRASE=your_polymarket_api_passphrase

# 3. YOUR POLYGON WALLET PRIVATE KEY
#    This is the wallet that will execute trades.
#    Use a DEDICATED wallet with only trading funds — never your main wallet.
WALLET_PRIVATE_KEY=your_wallet_private_key_here

# 4. POSITION SIZING — Fixed USDC per trade
FIXED_USDC_PER_TRADE=10.0
