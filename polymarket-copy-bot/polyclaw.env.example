# ─────────────────────────────────────────────────────
# SQI-2050 Polyclaw Bot — Environment Variables
# ─────────────────────────────────────────────────────

# Polygon RPC — free from Alchemy (alchemy.com)
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Polymarket API — from polymarket.com → Settings → API
POLY_API_KEY=your_api_key
POLY_API_SECRET=your_api_secret
POLY_API_PASSPHRASE=your_passphrase

# Your wallet private key (dedicated trading wallet only)
WALLET_PRIVATE_KEY=0x...

# Trading mode — start with true, switch to false when ready for live
PAPER_MODE=true

# Risk management
RISK_PCT=0.05              # 5% of balance per trade
MIN_TRADE_USDC=0.50        # minimum €0.50 per trade
MAX_TRADE_USDC=50.0       # maximum €50 per trade
KELLY_FRACTION=0.25        # quarter-Kelly (safest)
SCAN_INTERVAL_S=15         # scan every 15 seconds

# Strategy thresholds
ARB_THRESHOLD=0.97         # trigger arb if YES+NO < 0.97
NEWS_EDGE_MIN=0.04         # minimum 4% probability shift for news signal
