# Copy to .env.local (Vite) and fill for local / self-hosted builds.
# Lovable and other hosts usually inject these in the project settings instead.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Matches createClient in src/integrations/supabase/client.ts
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_or_publishable_key
# Optional alias some tooling uses (scan/chat fallback resolves it)
# VITE_SUPABASE_ANON_KEY=
# Lovable Cloud → Secrets often names the anon JWT SUPABASE_ANON_KEY (no VITE_ prefix).
# vite.config bridges SUPABASE_URL / SUPABASE_ANON_KEY into the VITE_* names at build time.
